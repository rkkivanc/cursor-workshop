# ──────────────────────────────────────────────────────────────────────────────
# MasterFabric Go Basic — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_DSN=postgres://masterfabric:masterfabric@localhost:5433/masterfabric_basic?sslmode=disable
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_IDLE=5m

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# ── Event Bus (RabbitMQ) ──────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5673/
RABBITMQ_ENABLED=true
RABBITMQ_EXCHANGE=masterfabric.events

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# IMPORTANT: change JWT_SECRET in production — must be at least 32 characters.
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h   # 7 days

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# LOG_FORMAT: json | text
LOG_FORMAT=json

# ── GraphQL ───────────────────────────────────────────────────────────────────
# Set to false in production to disable schema introspection.
GRAPHQL_INTROSPECTION=true
