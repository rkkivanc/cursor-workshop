# auth.graphqls — Authentication mutations and types

extend type Mutation {
  """Register a new user account and return auth tokens."""
  register(input: RegisterInput!): AuthPayload!

  """Log in with email and password."""
  login(input: LoginInput!): AuthPayload!

  """Exchange a refresh token for a new token pair."""
  refreshTokens(input: RefreshInput!): AuthPayload!

  """Revoke the current session (blacklists access token, deletes refresh token)."""
  logout(input: LogoutInput!): Boolean!
}

# ── Inputs ──────────────────────────────────────────────────────────────────

input RegisterInput {
  email:       String!
  password:    String!
  displayName: String!
}

input LoginInput {
  email:    String!
  password: String!
}

input RefreshInput {
  userID:       UUID!
  refreshToken: String!
}

input LogoutInput {
  userID:       UUID!
  accessToken:  String!
  refreshToken: String!
}

# ── Response types ───────────────────────────────────────────────────────────

type AuthPayload {
  accessToken:  String!
  refreshToken: String!
  expiresIn:    Int!
  user:         AuthUser!
}

type AuthUser {
  id:          UUID!
  email:       String!
  displayName: String!
  avatarURL:   String!
  role:        UserRole!
}
